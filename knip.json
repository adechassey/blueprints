{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"workspaces": {
		".": {
			"entry": ["scripts/*.ts"]
		},
		"webapp": {
			"entry": ["src/routes/**/*.tsx"],
			"project": ["src/**/*.{ts,tsx}"],
			"ignoreDependencies": ["@tanstack/router-devtools", "tailwindcss"]
		},
		"api": {
			"entry": ["src/db/index.ts"],
			"project": ["src/**/*.ts"],
			"ignoreDependencies": ["pgvector"]
		},
		"packages/shared": {
			"project": ["src/**/*.ts"]
		}
	}
}
