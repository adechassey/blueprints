{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"workspaces": {
		".": {
			"entry": ["scripts/*.ts"]
		},
		"webapp": {
			"entry": ["src/routes/**/*.tsx", "src/hooks/*.ts", "src/lib/*.ts"],
			"project": ["src/**/*.{ts,tsx}"],
			"ignoreDependencies": ["@tanstack/router-devtools", "tailwindcss", "@tailwindcss/typography"]
		},
		"api": {
			"entry": [
				"src/db/index.ts",
				"src/middleware/*.ts",
				"src/lib/*.ts",
				"src/mcp/*.ts"
			],
			"project": ["src/**/*.ts"],
			"ignoreDependencies": ["pgvector"]
		},
		"cli": {
			"entry": ["src/commands/*.ts", "src/lib/*.ts"],
			"project": ["src/**/*.ts"]
		},
		"packages/shared": {
			"project": ["src/**/*.ts"]
		}
	}
}
