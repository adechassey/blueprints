# =============================================================================
# Blueprints Server — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# -----------------------------------------------------------------------------
# Database (Phase 1)
# -----------------------------------------------------------------------------
# Local dev: start Docker with `docker compose up -d`, then use this URL:
DATABASE_URL="postgresql://blueprints:blueprints@localhost:5432/blueprints"

# Production: use your Neon connection string:
# DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/blueprints?sslmode=require"

# -----------------------------------------------------------------------------
# Authentication — Better Auth (Phase 2)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="generate-me-with-openssl-rand-base64-32"

# Google OAuth credentials (from Google Cloud Console)
# Configure at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs (dev):  http://localhost:3001/api/auth/callback/google
# Authorized JavaScript origins:   http://localhost:5173, http://localhost:3001
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Base URL for auth callbacks
# Dev: http://localhost:3001
# Prod: https://your-domain.com
BETTER_AUTH_URL="http://localhost:3001"

# -----------------------------------------------------------------------------
# Admin (Phase 6)
# -----------------------------------------------------------------------------
# Comma-separated list of emails that get admin role on first login
ADMIN_EMAILS="hugo.borsoni@theodo.com,antoine.de-chassey@theodo.com"

# -----------------------------------------------------------------------------
# App (Phase 1)
# -----------------------------------------------------------------------------
# API URL for the SPA to call
VITE_API_URL="http://localhost:3001"
