{
	"buildCommand": "drizzle-kit migrate",
	"builds": [
		{
			"src": "index.ts",
			"use": "@vercel/node",
			"config": {
				"excludeFiles": "{node_modules/@huggingface/**,node_modules/onnxruntime-*/**,node_modules/.pnpm/@huggingface+transformers*/**,node_modules/.pnpm/onnxruntime*/**}"
			}
		}
	],
	"routes": [{ "src": "/(.*)", "dest": "index.ts" }]
}
