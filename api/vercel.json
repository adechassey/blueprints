{
	"buildCommand": "pnpm --filter @blueprints/shared build && node bundle.mjs && pnpm --filter api run db:migrate",
	"builds": [
		{
			"src": "dist/index.mjs",
			"use": "@vercel/node",
			"config": {
				"excludeFiles": "{node_modules/@huggingface/**,node_modules/onnxruntime-node/**,node_modules/.pnpm/@huggingface*/**,node_modules/.pnpm/onnxruntime*/**}"
			}
		}
	],
	"routes": [{ "src": "/(.*)", "dest": "dist/index.mjs" }]
}
