{
	"buildCommand": "drizzle-kit migrate",
	"builds": [
		{
			"src": "index.ts",
			"use": "@vercel/node",
			"config": {
				"excludeFiles": "{node_modules/@huggingface/**,node_modules/onnxruntime-*/**}"
			}
		}
	],
	"routes": [{ "src": "/(.*)", "dest": "index.ts" }],
	"env": {
		"ENABLE_EXPERIMENTAL_COREPACK": "1"
	}
}
