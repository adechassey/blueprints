{
	"buildCommand": "pnpm --filter @blueprints/shared build && drizzle-kit migrate",
	"builds": [
		{
			"src": "index.ts",
			"use": "@vercel/node",
			"config": {
				"includeFiles": ["node_modules/@blueprints/shared/**"],
				"excludeFiles": "{node_modules/.pnpm/onnxruntime-node*/**/*cuda*,node_modules/.pnpm/onnxruntime-node*/**/*tensorrt*,node_modules/onnxruntime-node/**/*cuda*,node_modules/onnxruntime-node/**/*tensorrt*}"
			}
		}
	],
	"routes": [{ "src": "/(.*)", "dest": "index.ts" }]
}
